# Environment Variables — Required for Vercel Deployment
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit actual environment variable values to Git
# Add ALL of these in your Vercel project:
#   Dashboard → Project → Settings → Environment Variables

# ─── Resume ────────────────────────────────────────────
VITE_RESUME_URL=

# ─── Certificates (Cloudinary PDF URLs) ────────────────
VITE_CERT_1=
VITE_CERT_2=
VITE_CERT_3=
VITE_CERT_4=
VITE_CERT_5=
VITE_CERT_6=
VITE_CERT_7=
VITE_CERT_8=
VITE_CERT_9=
VITE_CERT_10=
VITE_CERT_11=
VITE_CERT_12=
VITE_CERT_13=
VITE_CERT_14=
VITE_CERT_15=
VITE_CERT_16=
VITE_CERT_17=
VITE_CERT_18=
VITE_CERT_19=
VITE_CERT_20=
VITE_CERT_21=
VITE_CERT_22=
VITE_CERT_23=
VITE_CERT_24=

# ─── Activity Dashboard ───────────────────────────────
# GitHub: classic PAT with read:user scope
VITE_GITHUB_TOKEN=
# LeetCode username (public, no auth needed)
VITE_LEETCODE_USERNAME=
