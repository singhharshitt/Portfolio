# Environment Variables Example
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit actual environment variable values

# GitHub Configuration (leave empty in production if not needed)
VITE_GITHUB_TOKEN=

# LeetCode Configuration  
VITE_LEETCODE_TOKEN=https://leetcode.com/graphql
VITE_LEETCODE_USERNAME=

# GeeksForGeeks Configuration
VITE_GFG_USERNAME=

# GitHub User Configuration
VITE_GITHUB_USERNAME=
