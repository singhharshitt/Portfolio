  "uniqueDecisions": [
    {
      "title": "Smart BaseURL Detection",
      "challenge": "Different URLs in development vs production",
      "solution": "Axios automatically detects localhost vs production environment",
      "benefits": ["Zero configuration needed", "Works across deployment platforms"]
    },
    {
      "title": "JWT Token Auto-Injection",
      "challenge": "Every protected API call needs authorization header",
      "solution": "Axios request interceptor auto-injects token from localStorage",
      "benefits": ["DRY principle", "Eliminates manual header construction"]
    },
    {
      "title": "Cloud Storage Migration",
      "challenge": "Local filesystem uploads don't scale with large files",
      "solution": "Migrated to Supabase for unlimited cloud storage + CDN",
      "benefits": ["Unlimited capacity", "Fast CDN delivery", "No server constraints"]
    },
    {
      "title": "Debounced Search",
      "challenge": "Search on every keystroke creates excessive API calls",
      "solution": "300ms debounce delay on search input",
      "benefits": ["90% fewer API calls", "Better UX", "Reduced server load"]
    },
    {
      "title": "Role-Based Access Control (3 layers)",
      "challenge": "Prevent unauthorized access to admin features",
      "solution": "Backend middleware + Frontend routing + UI visibility",
      "benefits": ["Defense in depth", "Seamless UX", "Separation of concerns"]
    }
  ],
