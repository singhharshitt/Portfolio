  "securityMeasures": [
    { "threat": "SQL Injection", "mitigation": "MongoDB + Mongoose prevents; no string concatenation" },
    { "threat": "XSS Attacks", "mitigation": "validator.escape() + React auto-escaping" },
    { "threat": "CSRF", "mitigation": "JWT in headers (not cookies) + CORS whitelist" },
    { "threat": "Weak Passwords", "mitigation": "Regex validation: 8+ chars, mixed case, number, special" },
    { "threat": "Password Storage", "mitigation": "bcryptjs with 12-round salt" },
    { "threat": "Unauthorized Access", "mitigation": "JWT validation + role-based middleware" },
    { "threat": "Session Hijacking", "mitigation": "7-day JWT expiration + HTTPS only" },
    { "threat": "Open CORS", "mitigation": "Whitelist only: localhost:5173 & production domain" }
  ],
  "databaseSchema": {
    "User": {
      "fields": [
        "name (string, 2-50 chars)",
        "username (string, unique, 3-30 alphanumeric+underscore)",
        "email (string, unique, validated)",
        "password (string, hashed with bcrypt)",
        "role (enum: 'user' | 'admin')",
        "lastLogin (date)",
        "timestamps (createdAt, updatedAt)"
      ]
    },
    "Book": {
      "fields": [
        "title (string, required, max 200)",
        "author (string, required, max 100)",
        "description (string, max 1000)",
        "category (string, required)",
        "fileUrl (string, PDF validation)",
        "coverImageUrl (string, default fallback)",
        "fileSize (number, min 1 byte)",
        "downloadCount (number, default 0)",
        "isFeatured (boolean)",
        "uploadedBy (ObjectId reference to User)",
        "timestamps"
      ]
    },
    "Request": {
      "fields": [
        "title (string, required, max 200)",
        "author (string, max 100)",
        "category (string, required)",
        "requestedBy (ObjectId reference to User)",
        "status (enum: 'Pending'|'Approved'|'Rejected'|'Fulfilled')",
        "fulfilledBook (ObjectId reference to Book, nullable)",
        "adminNotes (string)",
        "timestamps"
      ]
    },
    "Download": {
      "fields": [
        "user (ObjectId reference to User)",
        "book (ObjectId reference to Book)",
        "timestamps"
      ]
    }
  },
